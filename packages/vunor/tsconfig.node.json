{
  "extends": "@vue/tsconfig/tsconfig.json",
  "include": [
    "vite.config.*",
    "uno.config.*",
    "env.d.ts",
    "src/vite.ts",
    "src/nuxt.ts",
    "src/theme.ts",
    "src/theme/**/*.ts",
    "src/components/**/shortcuts.ts",
    "src/components/shortcuts.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "lib": ["ES2024", "DOM"],
    "types": ["node"],
    "paths": {
      "@nuxt/kit": ["./node_modules/@nuxt/kit"],
      "vunor": ["./src/vunor"],
      "vunor/utils": ["./src/utils"]
    }
  }
}
